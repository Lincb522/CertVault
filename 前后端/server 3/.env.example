# Server
PORT=3006
SERVER_URL=https://p12.zijiu522.cn

# PostgreSQL
PG_HOST=127.0.0.1
PG_PORT=5432
PG_DATABASE=CertManager
PG_USER=CertManager
PG_PASSWORD=your_password_here

# Encryption key (32 chars)
ENCRYPTION_KEY=your_32_char_encryption_key_here

# SMTP (optional, for email verification)
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your_email@example.com
SMTP_PASS=your_email_password

# APNs (optional)
APNS_SANDBOX=true

# App name (shown in mobileconfig profile)
APP_NAME=CertVault

# SSL for mobileconfig signing
# Default: data/ssl/fullchain.pem, data/ssl/privkey.key, data/ssl/chain.pem
# SSL_CERT_PATH=
# SSL_KEY_PATH=
# SSL_CHAIN_PATH=
