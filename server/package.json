{
  "name": "apple-cert-manager-server",
  "version": "1.0.0",
  "description": "Apple Developer Certificate Management Server",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "node --watch src/app.js",
    "pack": "npm ci --omit=dev",
    "docker:build": "docker build -t apple-cert-manager-server .",
    "docker:run": "docker run -p 3006:3006 -e PG_HOST -e PG_PORT -e PG_DATABASE -e PG_USER -e PG_PASSWORD -e ENCRYPTION_KEY --name cert-server apple-cert-manager-server"
  },
  "dependencies": {
    "archiver": "^7.0.1",
    "axios": "^1.7.0",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "node-forge": "^1.3.1",
    "nodemailer": "^8.0.1",
    "pg": "^8.19.0",
    "uuid": "^10.0.0"
  }
}
