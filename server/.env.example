# Basic server configuration
NODE_ENV=production
PORT=3006
SERVER_URL=https://your-domain.example
APP_NAME=CertVault

# PostgreSQL (required)
PG_HOST=127.0.0.1
PG_PORT=5432
PG_DATABASE=certvault
PG_USER=certvault
PG_PASSWORD=CHANGE_ME_DATABASE_PASSWORD

# Initial super administrator (required on first start)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME_STRONG_ADMIN_PASSWORD
ADMIN_EMAIL=

# SMTP (optional; required for email verification)
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME=CertVault

# APNs
APNS_SANDBOX=false

# Optional HTTP proxy, for example: http://127.0.0.1:7890
HTTP_PROXY=
HTTPS_PROXY=

# Optional external Token service
TOKEN_ADMIN_URL=http://127.0.0.1:3388
TOKEN_ADMIN_PASSWORD=

# Optional mobileconfig signing certificate paths
# SSL_CERT_PATH=/absolute/path/fullchain.pem
# SSL_KEY_PATH=/absolute/path/privkey.pem
# SSL_CHAIN_PATH=/absolute/path/chain.pem
